# ~/.bash_functions.sh
# Funções utilitárias carregadas pelo ~/.bashrc

# ====== Mini "framework" (cores + helpers) ======
# Só usa cor se o terminal suportar
__has_color() { [ -t 1 ] && command -v tput >/dev/null 2>&1 && [ "$(tput colors 2>/dev/null)" -ge 8 ]; }

__c() { # __c CODE "texto"
  if __has_color; then printf "\e[%sm%s\e[0m" "$1" "$2"; else printf "%s" "$2"; fi
}

msg()  { printf "%s\n" "$(__c '1;32' "✔") $*"; }
warn() { printf "%s\n" "$(__c '1;33' "⚠") $*"; }
err()  { printf "%s\n" "$(__c '1;31' "✖") $*"; }

need() { # need comando
  command -v "$1" >/dev/null 2>&1 || { err "Comando ausente: $1"; return 127; }
}

sep() { # sep [TITULO]
  local count="${SEP_WIDTH:-30}"
  local line
  line="$(printf "%*s" "$count" "" | tr " " "=")"

  echo
  if __has_color; then printf "\e[1;34m%s\e[0m\n" "$line"; else printf "%s\n" "$line"; fi
  [ -n "$1" ] && echo "$1"
  if __has_color; then printf "\e[1;34m%s\e[0m\n" "$line"; else printf "%s\n" "$line"; fi
  echo
}

# ====== Suas funções ======

df() {
  [ -x /usr/bin/df ] || { err "df não encontrado em /usr/bin/df"; return 127; }
  echo "==== Internal Disks ===="
  /usr/bin/df -hT | grep -E "^Filesystem|/dev/sd|/dev/nvme|/dev/mmc" | column -t
  echo
  echo "==== Removable Disks ===="
  /usr/bin/df -hT | grep -E "/media|/mnt" | column -t
}


bigdirs() {
  need du || return
  need sort || return
  need head || return

  local target="${1:-.}"
  local limit="${2:-20}"

  sudo du -xh --max-depth=1 \
    --exclude=/proc \
    --exclude=/sys \
    --exclude=/dev \
    --exclude=/run \
    --exclude=/snap \
    --exclude=/tmp \
    "$target" 2>/dev/null \
  | sort -hr \
  | head -n "$limit"
}

bigarchives() {
  need find || return
  need sort || return
  need head || return

  local target="${1:-$HOME}"
  local size="${2:-5G}"
  local limit="${3:-20}"

  sudo find "$target" -xdev \
    \( -path /proc -o -path /sys -o -path /dev -o -path /run -o -path /tmp \) -prune -o \
    -type f \( \
      -iname "*.zip" -o -iname "*.tar" -o -iname "*.tar.gz" -o -iname "*.tgz" \
      -o -iname "*.gz" -o -iname "*.7z" -o -iname "*.rar" \
    \) -size +"$size" -printf '%s\t%p\n' 2>/dev/null \
  | sort -nr \
  | head -n "$limit" \
  | awk '{
      size=$1
      path=$2
      unit="B"
      if (size>=1024){size/=1024;unit="K"}
      if (size>=1024){size/=1024;unit="M"}
      if (size>=1024){size/=1024;unit="G"}
      if (size>=1024){size/=1024;unit="T"}
      printf "%.1f%s\t%s\n", size, unit, path
    }'
}



size() {
  if [ $# -eq 0 ]; then
    sep  "  Disk usage helpers"
    echo "  size dirs [PATH] [N]          → Top N diretórios maiores"
    echo "  size archives [PATH] [SIZE] [N] → Archives maiores que SIZE"
    echo
    echo "Exemplos:"
    echo "  size dirs      ex.:/container/proc/ mostra o tamanho do diretório proc/"
    echo
    echo "  size archives  ex.:/home   mostra o tamnhado do diretório home"
    echo
    return 0
  fi

  case "$1" in
    dirs)     shift; bigdirs "$@";;
    archives) shift; bigarchives "$@";;
    help|-h|--help) shift; size;;
    *) err "Opção inválida: $1"; warn "Use: size"; return 2;;
  esac
}


scp() {
    if [ $# -eq 0 ]; then
        echo -e "\n🚀 Tip: Use scp like this → scp FILE user@host:/path/"
        echo -e "Example: scp data.txt radaz@192.168.0.10:/tmp/\n"
    else
        command /usr/bin/scp "$@"
    fi
}

rsync() {
    if [ $# -eq 0 ]; then
        echo -e "\n📦 Tip: Use rsync like this:"
