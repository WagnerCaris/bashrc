# Essa função abre uma aplicação e fecha seu terminal.
# Ex.: no terminal digite "gui qgis" e o QGIS será aberto sem o terminal.
gui() {
  need_bin /usr/bin/setsid || return
  /usr/bin/setsid -f "$@" >/dev/null 2>&1 < /dev/null
  exit
}
