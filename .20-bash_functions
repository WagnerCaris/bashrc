# ------------------------------
# Inspecionar um serviço específico
# Uso: svc ssh
#      svc ssh.service
# ------------------------------
svc() {
  _svc_init_colors

  if [ -z "$1" ]; then
    printf "%bUso:%b svc <servico>\n" "$SVC_BOLD" "$SVC_RESET"
    printf "Exemplos:\n"
    printf "  svc ssh\n"
    printf "  svc NetworkManager\n"
    printf "  svc zerotier-one.service\n"
    return 1
  fi

  local unit="$1"
  if [[ "$unit" != *.service ]]; then
    unit="${unit}.service"
  fi

  _svc_header "STATUS: ${unit}"
  sudo systemctl status --no-pager --full "$unit"

  echo
  _svc_header "LOGS DO BOOT ATUAL: ${unit}"
  sudo journalctl -u "$unit" -b --no-pager -n 50
}
