        echo
        echo -e "Examples:"
        echo -e "  Local → local:"
        echo -e "    rsync -avh --progress /home/proc/ /mnt/backup/"
        echo
        echo -e "  Local → remote:"
        echo -e "    rsync -avh --progress /home/proc/archive.txt radaz@192.168.8.15:/mnt/backup/\n"
    else
        command /usr/bin/rsync "$@"
    fi
}


ssh() {
    if [ $# -eq 0 ]; then
        echo -e "\n🔐 Tip: Use SSH like this → ssh -X user@host"
        echo -e "Example: ssh -X radaz@192.168.0.10\n"
    else
        command /usr/bin/ssh "$@"
    fi
}


extract () {
    if [ -f "$1" ]; then
       	case "$1" in
           	*.tar.bz2)   tar xjf "$1" ;;
           	*.tar.gz)    tar xzf "$1" ;;
           	*.tar.xz)    tar xJf "$1" ;;
           	*.tar.zst)   tar --zstd -xf "$1" ;;
           	*.tar)       tar xf "$1" ;;
           	*.tbz2)      tar xjf "$1" ;;
           	*.tgz)       tar xzf "$1" ;;
           	*.zip)       unzip "$1" ;;
           	*.rar)       unrar x "$1" ;;
           	*.7z)        7z x "$1" ;;
           	*.gz)        gunzip "$1" ;;
           	*.bz2)       bunzip2 "$1" ;;
           	*.xz)        unxz "$1" ;;
           	*.Z)         uncompress "$1" ;;
           	*)           echo "extract: '$1' - unsupported file type" ;;
       	esac
   	else
   	    echo "extract: '$1' is not a valid file"
   	fi
}







# Função que detecta automaticamente a sub-rede e faz o scan amigável
nmapscan() {
    local detected_ip input range
    local oct1 oct2 oct3 oct4 oct mask

    command -v nmap >/dev/null 2>&1 || {
        echo "Erro: nmap não está instalado."
        echo "Instale com: sudo apt install nmap"
        return 1
    }

    detected_ip=$(hostname -I 2>/dev/null | awk '{print $1}')

    echo "Informe um IP ou uma rede CIDR para escaneamento."
    echo "Exemplos:"
    echo "  192.168.168.36      -> escaneia 192.168.168.0/24"
    echo "  192.168.168.0/24    -> escaneia exatamente essa rede"
    echo "  10.0.0.0/16         -> escaneia exatamente essa rede"
    echo

    read -r -e -p "IP ou rede [${detected_ip}]: " input
    input=${input:-$detected_ip}

    if [[ -z "$input" ]]; then
        echo "Erro: não foi possível detectar IP automaticamente e nada foi informado."
        return 2
    fi

    if [[ "$input" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}/[0-9]{1,2}$ ]]; then
        IFS='/.' read -r oct1 oct2 oct3 oct4 mask <<< "$input"

        for oct in "$oct1" "$oct2" "$oct3" "$oct4"; do
            if ! [[ "$oct" =~ ^[0-9]+$ ]] || [ "$oct" -lt 0 ] || [ "$oct" -gt 255 ]; then
                echo "Erro: rede CIDR inválida."
                return 2
            fi
        done

        if ! [[ "$mask" =~ ^[0-9]+$ ]] || [ "$mask" -lt 0 ] || [ "$mask" -gt 32 ]; then
            echo "Erro: máscara CIDR inválida."
            return 2
        fi

        range="$input"

    elif [[ "$input" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
        IFS='.' read -r oct1 oct2 oct3 oct4 <<< "$input"

        for oct in "$oct1" "$oct2" "$oct3" "$oct4"; do
            if ! [[ "$oct" =~ ^[0-9]+$ ]] || [ "$oct" -lt 0 ] || [ "$oct" -gt 255 ]; then
                echo "Erro: IP inválido."
                return 2
            fi
        done

        range="${oct1}.${oct2}.${oct3}.0/24"

    else
        echo "Erro: entrada inválida."
        echo "Use um IP (ex.: 192.168.168.36) ou CIDR (ex.: 192.168.168.0/24)."
        return 2
    fi

    echo
    echo "=================================================="
    echo "Escaneando rede: $range"
    echo "Comando: sudo nmap -sn $range"
    echo "=================================================="

    sudo nmap -sn "$range" 2>/dev/null | awk '
        /^Nmap scan report for / {
            if (host_printed) printf "\n"
            host=$NF
            printf "Host: %-16s", host
            host_printed=1
            mac_printed=0
        }
        /^MAC Address: / {
            mac=$3
            vendor=""
            for (i=4; i<=NF; i++) {
                vendor = vendor $i (i<NF ? " " : "")
            }
            gsub(/[()]/, "", vendor)
            printf "  MAC: %-18s  Fabricante: %s", mac, vendor
            mac_printed=1
        }
        END {
            if (host_printed) printf "\n"
        }
    '

    echo
}





