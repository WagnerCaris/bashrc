# ------------------------------
# Helpers para visualizar serviços systemd
# ------------------------------

_svc_init_colors() {
  SVC_RESET=$'\033[0m'
  SVC_BOLD=$'\033[1m'

  SVC_RED=$'\033[31m'
  SVC_GREEN=$'\033[32m'
  SVC_YELLOW=$'\033[33m'
  SVC_BLUE=$'\033[34m'
  SVC_MAGENTA=$'\033[35m'
  SVC_CYAN=$'\033[36m'
  SVC_GRAY=$'\033[90m'
}

_svc_sep() {
  local w="${SEP_WIDTH:-100}"
  printf '%*s\n' "$w" '' | tr ' ' '='
}

_svc_header() {
  _svc_sep
  printf "%b%s%b\n" "${SVC_BOLD}${SVC_CYAN}" "$1" "$SVC_RESET"
  _svc_sep
}

_svc_summary_counts() {
  local running_count failed_count inactive_count
  local enabled_count disabled_count masked_count static_count

  running_count=$(
    systemctl list-units --type=service --state=running --plain --no-pager --no-legend 2>/dev/null \
      | awk '$1 ~ /\.service$/ {n++} END {print n+0}'
  )

  failed_count=$(
    systemctl list-units --type=service --state=failed --plain --no-pager --no-legend 2>/dev/null \
      | awk '$1 ~ /\.service$/ {n++} END {print n+0}'
  )

  inactive_count=$(
    systemctl list-units --type=service --state=inactive --plain --no-pager --no-legend 2>/dev/null \
      | awk '$1 ~ /\.service$/ {n++} END {print n+0}'
  )

  read -r enabled_count disabled_count masked_count static_count < <(
    systemctl list-unit-files --type=service --plain --no-pager --no-legend 2>/dev/null \
      | awk '
          $2=="enabled"  {e++}
          $2=="disabled" {d++}
          $2=="masked"   {m++}
          $2=="static"   {s++}
          END {print e+0, d+0, m+0, s+0}
        '
  )

  printf "%bResumo:%b " "$SVC_BOLD" "$SVC_RESET"
  printf "%brunning=%s%b  " "$SVC_GREEN" "$running_count" "$SVC_RESET"
  printf "%bfailed=%s%b  " "$SVC_RED" "$failed_count" "$SVC_RESET"
  printf "%binactive=%s%b  " "$SVC_YELLOW" "$inactive_count" "$SVC_RESET"
  printf "%benabled=%s%b  " "$SVC_BLUE" "$enabled_count" "$SVC_RESET"
  printf "%bdisabled=%s%b  " "$SVC_MAGENTA" "$disabled_count" "$SVC_RESET"
  printf "%bmasked=%s%b  " "$SVC_RED" "$masked_count" "$SVC_RESET"
  printf "%bstatic=%s%b\n" "$SVC_GRAY" "$static_count" "$SVC_RESET"
}

_svc_legend_short() {
  printf "%bLegenda:%b\n" "$SVC_BOLD" "$SVC_RESET"
  printf "  %brunning%b   = serviço em execução agora\n" "$SVC_GREEN" "$SVC_RESET"
  printf "  %bfailed%b    = serviço falhou\n" "$SVC_RED" "$SVC_RESET"
  printf "  %benabled%b   = inicia automaticamente no boot\n" "$SVC_BLUE" "$SVC_RESET"
  printf "  %bdisabled%b  = não inicia automaticamente no boot\n" "$SVC_MAGENTA" "$SVC_RESET"
  printf "  %bmasked%b    = bloqueado; não pode iniciar normalmente\n" "$SVC_RED" "$SVC_RESET"
  printf "  %bstatic%b    = não é habilitado diretamente; costuma ser acionado por outra unit\n" "$SVC_GRAY" "$SVC_RESET"
}

_svc_legend_all() {
  printf "%bLegenda:%b\n" "$SVC_BOLD" "$SVC_RESET"
  printf "  %brunning%b         = serviço em execução agora\n" "$SVC_GREEN" "$SVC_RESET"
  printf "  %bfailed%b          = serviço falhou\n" "$SVC_RED" "$SVC_RESET"
  printf "  %binactive%b        = carregado, mas não está rodando agora; muitas vezes é normal\n" "$SVC_YELLOW" "$SVC_RESET"
  printf "  %benabled%b         = inicia automaticamente no boot\n" "$SVC_BLUE" "$SVC_RESET"
  printf "  %bdisabled%b        = não inicia automaticamente no boot\n" "$SVC_MAGENTA" "$SVC_RESET"
  printf "  %bmasked%b          = bloqueado; start manual normal não funciona\n" "$SVC_RED" "$SVC_RESET"
  printf "  %bstatic%b          = não se habilita com enable; geralmente depende de outra unit\n" "$SVC_GRAY" "$SVC_RESET"
  printf "  alias               = outro nome para uma unit\n"
  printf "  indirect            = unit auxiliar/indireta; normalmente não é ativada diretamente\n"
  printf "  enabled-runtime     = habilitada apenas no runtime atual\n"
}

_svc_print_running() {
  systemctl list-units --type=service --state=running --plain --no-pager --no-legend 2>/dev/null \
    | awk -v G="$SVC_GREEN" -v R="$SVC_RESET" '
        $1 ~ /\.service$/ {
          unit_name=$1
          active_state=$3
          sub_state=$4
          printf "%-45s %-10s %s%s%s\n", unit_name, active_state, G, sub_state, R
        }
      '
}

_svc_print_failed() {
  local count
  count=$(
    systemctl list-units --type=service --state=failed --plain --no-pager --no-legend 2>/dev/null \
      | awk '$1 ~ /\.service$/ {n++} END {print n+0}'
  )

  if [ "$count" -eq 0 ]; then
    printf "%bNenhum serviço failed.%b\n" "$SVC_GREEN" "$SVC_RESET"
    return
  fi

  systemctl list-units --type=service --state=failed --plain --no-pager --no-legend 2>/dev/null \
    | awk -v C="$SVC_RED" -v R="$SVC_RESET" '
        $1 ~ /\.service$/ {
          unit_name=$1
          active_state=$3
          sub_state=$4
          printf "%-45s %-10s %s%s%s\n", unit_name, active_state, C, sub_state, R
        }
      '
}

_svc_print_inactive() {
  systemctl list-units --type=service --state=inactive --plain --no-pager --no-legend 2>/dev/null \
    | awk -v C="$SVC_YELLOW" -v R="$SVC_RESET" '
        $1 ~ /\.service$/ {
          unit_name=$1
          load_state=$2
          active_state=$3
          sub_state=($4 ? $4 : "-")
          printf "%-45s %-10s %s%-10s%s %s\n", unit_name, load_state, C, active_state, R, sub_state
        }
      '
}

_svc_print_unit_files_short() {
  printf "%-45s %-16s\n" "SERVIÇO" "ESTADO"
  printf "%-45s %-16s\n" "-------" "------"

  systemctl list-unit-files --type=service --plain --no-pager --no-legend 2>/dev/null \
    | awk -v BLUE="$SVC_BLUE" -v MAG="$SVC_MAGENTA" -v RED="$SVC_RED" -v GRAY="$SVC_GRAY" -v R="$SVC_RESET" '
        $2=="enabled"  { printf "%-45s %s%-16s%s\n", $1, BLUE, $2, R }
        $2=="disabled" { printf "%-45s %s%-16s%s\n", $1, MAG,  $2, R }
        $2=="masked"   { printf "%-45s %s%-16s%s\n", $1, RED,  $2, R }
        $2=="static"   { printf "%-45s %s%-16s%s\n", $1, GRAY, $2, R }
      '
}

_svc_print_unit_files_all() {
  printf "%-45s %-16s\n" "SERVIÇO" "ESTADO"
  printf "%-45s %-16s\n" "-------" "------"

  systemctl list-unit-files --type=service --plain --no-pager --no-legend 2>/dev/null \
    | awk -v BLUE="$SVC_BLUE" -v MAG="$SVC_MAGENTA" -v RED="$SVC_RED" -v GRAY="$SVC_GRAY" -v R="$SVC_RESET" '
        {
          state=$2
          color=""
          if (state=="enabled" || state=="enabled-runtime") {
            color=BLUE
          } else if (state=="disabled") {
            color=MAG
          } else if (state=="masked") {
            color=RED
          } else if (state=="static") {
            color=GRAY
          }

          if (color != "") {
            printf "%-45s %s%-16s%s\n", $1, color, state, R
          } else {
            printf "%-45s %-16s\n", $1, state
          }
        }
      '
}

