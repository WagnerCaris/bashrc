# ===== Navegação =====
alias doc='cd ~/Documentos'
alias dow='cd ~/Downloads'
alias proc='cd /container/proc'


# ===== Listagem =====
alias l='eza -la'
alias ll='eza -lah --group-directories-first'
alias ls='ls --color=auto'
#alias nano='micro'

# ===== Segurança / interativo =====
alias rm='rm -I --preserve-root'   # Ask before removing sudo files
alias mkdir='mkdir -pv' # Show created dirs


# ===== Conveniência =====
alias c='clear'
alias e='exit'

# ===== Atalhos específicos =====
alias mmi='cat /opt/os/app/configs/mmi/mmi.config'
alias mc='. /usr/lib/mc/mc-wrapper.sh'
